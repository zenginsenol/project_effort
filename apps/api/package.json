{
  "name": "@estimate-pro/api",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./routers": "./src/routers/index.ts"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "lint": "ESLINT_USE_FLAT_CONFIG=false eslint \"src/**/*.{ts,tsx}\"",
    "test": "vitest run --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.77.0",
    "@clerk/backend": "^1.20.0",
    "@estimate-pro/db": "workspace:*",
    "@estimate-pro/errors": "workspace:*",
    "@estimate-pro/types": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.4.0",
    "@trpc/server": "^11.0.0-rc.682",
    "drizzle-orm": "^0.38.4",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "mammoth": "^1.11.0",
    "openai": "^6.22.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pino": "^9.6.0",
    "socket.io": "^4.8.3",
    "superjson": "^2.2.2",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@estimate-pro/eslint-config": "workspace:*",
    "@estimate-pro/typescript-config": "workspace:*",
    "dotenv": "^16.4.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  }
}
